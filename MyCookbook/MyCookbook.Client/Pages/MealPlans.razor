@page "/mealplans"
@using MyCookbook.Shared
@using MyCookbook.Shared.DTOs.MealPlanDTOs

@rendermode InteractiveWebAssembly
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Jídelníčky - My Cookbook</PageTitle>

<div class="page-header">
    <h2>Moje jídelníčky</h2>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="recipe-form-container">
    <button class="action-button primary" type="button" @onclick="GoToNewMealPlan">Nový jídelníček</button>

    @if (mealPlans == null)
    {
        <div class="recipe-loading">
            <i class="bi bi-clock"></i>
            Načítám jídelníčky...
        </div>
    }
    else if (mealPlans.Count == 0)
    {
        <p class="empty-recipes">Zatím nemáš žádný jídelníček.</p>
    }
    else
    {
        <div class="mealplan-list mt-3">
            @foreach (var plan in mealPlans)
            {
                <div class="mealplan-card"
                     @onclick="() => OpenDetail(plan.Id)">

                    <div class="mealplan-card-header">
                        <h3>@plan.Name</h3>

                        <div>
                            <button class="icon-button"
                                    title="Přejmenovat"
                                    @onclick:stopPropagation="true">
                                <i class="fa-solid fa-pen icon"></i>
                            </button>

                            <button class="icon-button"
                                    title="Duplikovat"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => DuplicateMealPlan(plan.Id)">
                                <i class="fa-solid fa-copy icon"></i>
                            </button>

                            <button class="icon-button danger"
                                    title="Smazat"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ConfirmDelete(plan.Id)">
                                <i class="fa-solid fa-trash icon"></i>
                            </button>
                        </div>

                    </div>

                    <div class="mealplan-card-meta">
                        <span>
                            @DayOfWeekExtensions.CzechNames[plan.StartDayOfWeek]
                            –
                            @DayOfWeekExtensions.CzechNames[
                            (DayOfWeek)(((int)plan.StartDayOfWeek + plan.Days - 1) % 7)
                                        ]
                        </span>
                        <span>· @plan.Days @plan.Days.CzechDays()</span>
                    </div>

            <div class="mealplan-card-date">
                Vytvořeno: @plan.CreatedAt.ToLocalTime().ToShortDateString()
            </div>

                </div>
                }
        </div>
    }
</div>

@code {
    private List<MealPlanListDto> mealPlans = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/mealplans");

            if (response.IsSuccessStatusCode)
            {
                mealPlans = await response.Content.ReadFromJsonAsync<List<MealPlanListDto>>()
                    ?? new List<MealPlanListDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }


    private void GoToNewMealPlan()
    {
        NavigationManager.NavigateTo("/newmealplan");
    }

    private void OpenDetail(int id)
    {
        NavigationManager.NavigateTo($"/mealplans/{id}");
    }    

    private async Task ConfirmDelete(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Opravdu chceš tento jídelníček smazat?"
        );

        if (!confirmed)
            return;

        await DeleteMealPlan(id);
    }

    private async Task DeleteMealPlan(int id)
    {
        errorMessage = null;

        try 
        {
            var response = await Http.DeleteAsync($"api/mealplans/{id}");

            if (response.IsSuccessStatusCode)
            {
                var plan = mealPlans.FirstOrDefault(p => p.Id == id);

                if (plan != null)
                    mealPlans.Remove(plan);                
            }
            else
            {
                var serverMessage = await response.Content.ReadAsStringAsync();

                errorMessage = string.IsNullOrWhiteSpace(serverMessage)
                    ? "Nepodařilo se smazat jídelníček."
                    : serverMessage;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        StateHasChanged();
    }

    private async Task DuplicateMealPlan(int id)
    {
        errorMessage = null;

        try
        {
            var response = await Http.PostAsync($"api/mealplans/{id}/duplicate", null);

            if (response.IsSuccessStatusCode)
            {
                var newPlan = await response.Content.ReadFromJsonAsync<MealPlanListDto>();

                if (newPlan != null)
                    mealPlans.Add(newPlan);
            }
            else
            {
                var message = await response.Content.ReadAsStringAsync();
                errorMessage = string.IsNullOrWhiteSpace(message)
                    ? "Nepodařilo se duplikovat jídelníček."
                    : message;
            }
        } 
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        StateHasChanged();
    }
}
